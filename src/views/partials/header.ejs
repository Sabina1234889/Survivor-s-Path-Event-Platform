<!DOCTYPE html>
<html lang="<%= lang %>" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= i18n.brand %> | <%= i18n.tagline %></title>
  
  <!-- Tailwind CSS via CDN / compiled stylesheet -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Font & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Custom 3D Glassmorphism Stylesheet -->
  <link rel="stylesheet" href="/css/glassmorphism.css" />
  
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['"Plus Jakarta Sans"', 'sans-serif'],
          },
          colors: {
            brand: {
              50: '#f0f9ff',
              400: '#38bdf8',
              500: '#0ea5e9',
              600: '#0284c7',
              900: '#0f172a',
            }
          }
        }
      }
    }
  </script>
</head>
<body class="min-h-screen flex flex-col justify-between text-slate-100 antialiased selection:bg-cyan-500 selection:text-slate-950">

  <!-- Ambient Glowing Background Orbs -->
  <div class="orb w-96 h-96 bg-cyan-500/20 top-0 -left-20"></div>
  <div class="orb w-96 h-96 bg-purple-600/20 top-1/3 -right-20"></div>
  <div class="orb w-96 h-96 bg-emerald-500/15 bottom-0 left-1/3"></div>

  <!-- Main Navigation Bar -->
  <header class="sticky top-0 z-50 px-4 py-3 sm:px-8">
    <nav class="max-w-7xl mx-auto glass-panel px-6 py-3.5 flex items-center justify-between">
      
      <!-- Brand Logo & 3D Emblem -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-cyan-500 via-indigo-500 to-purple-600 p-[1.5px] shadow-lg shadow-cyan-500/20 group-hover:scale-105 transition-transform">
          <div class="w-full h-full bg-slate-950 rounded-[10px] flex items-center justify-center font-black text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-emerald-400 text-xl">
            SP
          </div>
        </div>
        <div>
          <span class="font-extrabold text-lg sm:text-xl tracking-tight text-white block leading-tight group-hover:text-cyan-300 transition-colors">
            <%= i18n.brand %>
          </span>
          <span class="text-[10px] font-medium text-cyan-400 uppercase tracking-wider block">
            Youth Platform
          </span>
        </div>
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden md:flex items-center gap-5 text-sm font-medium text-slate-300">
        <a href="/" class="hover:text-cyan-400 transition-colors"><%= i18n.nav.home %></a>
        <a href="/events" class="hover:text-cyan-400 transition-colors"><%= i18n.nav.events %></a>
        <a href="/my-tickets" class="hover:text-cyan-400 transition-colors flex items-center gap-1">
          <span><%= i18n.nav.myTickets %></span>
          <% if (typeof myTicketsCount !== 'undefined' && myTicketsCount > 0) { %>
            <span class="bg-cyan-500/30 text-cyan-300 text-xs px-2 py-0.5 rounded-full border border-cyan-400/30">
              <%= myTicketsCount %>
            </span>
          <% } %>
        </a>
        <a href="/faq" class="hover:text-cyan-400 transition-colors"><%= i18n.nav.faq %></a>
        <a href="/support" class="hover:text-cyan-400 transition-colors"><%= i18n.nav.support %></a>
        <% if (currentUser && (currentUser.role === 'admin' || currentUser.email === 'mdanontosunny1068@gmail.com')) { %>
          <a href="/admin/sheets" class="hover:text-emerald-400 transition-colors flex items-center gap-1.5 text-xs bg-emerald-950/40 border border-emerald-500/30 px-3 py-1.5 rounded-lg text-emerald-300">
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            <span><%= i18n.nav.sheetsAdmin %></span>
          </a>
        <% } %>
        <a href="/scanner" class="hover:text-purple-400 transition-colors flex items-center gap-1.5 text-xs bg-purple-950/40 border border-purple-500/30 px-3 py-1.5 rounded-lg text-purple-300">
          <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path></svg>
          <span><%= i18n.nav.scanner %></span>
        </a>
      </div>

      <!-- User Auth & Bilingual Language Toggle -->
      <div class="flex items-center gap-3">
        
        <!-- Bilingual Language Toggle Button -->
        <a href="/set-lang?lang=<%= lang === 'en' ? 'bn' : 'en' %>&redirect=<%= encodeURIComponent(typeof currentUrl !== 'undefined' ? currentUrl : '/') %>" 
           class="flex items-center gap-1.5 bg-slate-900/80 border border-slate-700/60 hover:border-cyan-500/60 text-xs px-3 py-1.5 rounded-lg transition-all font-semibold text-cyan-300 shadow-inner"
           title="Switch Language">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1 4h6m-1 0l4 10M14 19l-1.5-3.5M3 19h18M5 19l3.8-9.5"></path></svg>
          <span><%= lang === 'en' ? 'বাংলা (BN)' : 'English (EN)' %></span>
        </a>

        <!-- User Profile / Login / Sign Up -->
        <% if (currentUser) { %>
          <div class="flex items-center gap-2 bg-slate-900/90 border border-cyan-500/30 px-3 py-1.5 rounded-xl hover:border-cyan-400 transition-all">
            <a href="/profile" class="flex items-center gap-2 hover:opacity-90" title="View Profile Dashboard">
              <div class="w-6 h-6 rounded-full bg-gradient-to-tr from-cyan-400 to-indigo-500 flex items-center justify-center font-bold text-[10px] text-slate-950">
                <%= currentUser.name.charAt(0) %>
              </div>
              <span class="text-xs font-semibold text-slate-200 hidden sm:inline"><%= currentUser.name.split(' ')[0] %></span>
            </a>
            <a href="/logout" class="text-xs text-rose-400 hover:text-rose-300 ml-1.5 border-l border-slate-800 pl-2" title="<%= i18n.nav.logout %>">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
            </a>
          </div>
        <% } else { %>
          <div class="flex items-center gap-2">
            <a href="/login" class="text-slate-300 hover:text-white font-bold text-xs px-3 py-2 rounded-xl transition-all">
              <%= i18n.nav.login %>
            </a>
            <a href="/signup" class="bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-slate-950 font-extrabold text-xs px-3.5 py-2 rounded-xl transition-all shadow-md shadow-cyan-500/20 active:scale-95">
              Sign Up
            </a>
          </div>
        <% } %>

      </div>

    </nav>
  </header>

  <!-- Main Content Container -->
  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-8 py-6 z-10">
