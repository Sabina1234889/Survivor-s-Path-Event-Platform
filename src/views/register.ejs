<%- include('partials/header') %>

<% 
  const eventTitle = lang === 'bn' ? event.titleBn : event.titleEn;
%>

<div class="max-w-2xl mx-auto space-y-8 py-4">

  <!-- Back Link -->
  <a href="/events/<%= event.slug %>" class="inline-flex items-center gap-2 text-xs font-bold text-cyan-400 hover:text-cyan-300 transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
    <span>Back to Event Details</span>
  </a>

  <!-- Capacity / Waitlist Status Notice Banner -->
  <% if (isWaitlist) { %>
    <div class="p-4 rounded-2xl bg-amber-950/80 border border-amber-500/50 flex items-start gap-3 shadow-lg shadow-amber-950/50">
      <div class="p-2 rounded-xl bg-amber-500/20 text-amber-400 flex-shrink-0">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
      </div>
      <div>
        <div class="text-sm font-bold text-amber-300">Waitlist Mode Active</div>
        <div class="text-xs text-amber-200/80 mt-1 leading-relaxed">
          <%= i18n.registration.waitlistNotice %>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="p-4 rounded-2xl bg-emerald-950/80 border border-emerald-500/50 flex items-start gap-3 shadow-lg shadow-emerald-950/50">
      <div class="p-2 rounded-xl bg-emerald-500/20 text-emerald-400 flex-shrink-0">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      </div>
      <div>
        <div class="text-sm font-bold text-emerald-300">Guaranteed Seat Available</div>
        <div class="text-xs text-emerald-200/80 mt-1 leading-relaxed">
          <%= i18n.registration.registeredNotice %> (<%= spotsLeft %> spots remaining)
        </div>
      </div>
    </div>
  <% } %>

  <!-- Registration Form Card -->
  <div class="glass-panel p-8 rounded-3xl border border-cyan-500/30 space-y-6">
    
    <div>
      <h1 class="text-2xl font-extrabold text-white tracking-tight">
        <%= i18n.registration.title %>
      </h1>
      <p class="text-xs text-slate-400 mt-1">
        Registering for: <strong class="text-cyan-300"><%= eventTitle %></strong>
      </p>
    </div>

    <!-- Express POST Registration Form -->
    <form action="/events/<%= event.slug %>/register" method="POST" class="space-y-4">
      
      <!-- Full Name -->
      <div>
        <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
          <%= i18n.registration.fullName %> *
        </label>
        <input type="text" name="fullName" required 
               value="<%= currentUser ? currentUser.name : '' %>"
               placeholder="e.g. Anika Rahman"
               class="w-full bg-slate-950/80 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-cyan-500/20 transition-all" />
      </div>

      <!-- Email & Phone -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            <%= i18n.registration.email %> *
          </label>
          <input type="email" name="email" required 
                 value="<%= currentUser ? currentUser.email : '' %>"
                 placeholder="your.email@example.com"
                 class="w-full bg-slate-950/80 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-cyan-500/20 transition-all" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            <%= i18n.registration.phone %> *
          </label>
          <input type="tel" name="phone" required 
                 placeholder="+880 1712-345678"
                 value="+880 1712-345678"
                 class="w-full bg-slate-950/80 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-cyan-500/20 transition-all" />
        </div>
      </div>

      <!-- Organization & Youth Group -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            <%= i18n.registration.organization %> *
          </label>
          <input type="text" name="organization" required 
                 placeholder="e.g. Dhaka University Youth Club"
                 value="University Youth Club"
                 class="w-full bg-slate-950/80 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-cyan-500/20 transition-all" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            <%= i18n.registration.youthGroup %> *
          </label>
          <input type="text" name="youthGroup" required 
                 placeholder="e.g. Central Chapter"
                 value="District Leadership Wing"
                 class="w-full bg-slate-950/80 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-cyan-500/20 transition-all" />
        </div>
      </div>

      <!-- Age & Emergency Contact -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            <%= i18n.registration.age %> *
          </label>
          <input type="number" name="age" min="12" max="35" required 
                 value="21"
                 class="w-full bg-slate-950/80 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-cyan-500/20 transition-all" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            <%= i18n.registration.emergencyContact %> *
          </label>
          <input type="tel" name="emergencyContact" required 
                 placeholder="+880 1819-000000"
                 value="+880 1819-000000"
                 class="w-full bg-slate-950/80 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-cyan-500/20 transition-all" />
        </div>
      </div>

      <!-- Free vs. Paid Event Payment Section -->
      <% if (event.isPaid) { %>
        <div class="p-5 rounded-2xl bg-slate-950/90 border border-cyan-500/40 space-y-4 shadow-xl">
          <div class="flex items-center justify-between border-b border-slate-800 pb-3">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-amber-400 animate-pulse"></span>
              <h3 class="text-sm font-black text-amber-300 uppercase tracking-wider">Paid Event Registration Fee</h3>
            </div>
            <span class="text-lg font-black text-cyan-300 bg-cyan-950/90 px-3 py-1 rounded-xl border border-cyan-500/40">
              ৳<%= event.price %> BDT
            </span>
          </div>

          <div class="text-xs text-slate-300 bg-slate-900/80 p-3 rounded-xl border border-slate-800 leading-relaxed">
            <span class="font-bold text-amber-400 block mb-1">Payment Instructions:</span>
            <%= event.paymentInstructions || 'Send registration fee via bKash / Nagad Personal to +880 1711-223344' %>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-1">
            <div>
              <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
                Payment Method *
              </label>
              <select name="paymentMethod" required class="w-full bg-slate-900 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none transition-all">
                <option value="bKash" selected>bKash Personal</option>
                <option value="Nagad">Nagad Personal</option>
                <option value="Rocket">Rocket</option>
                <option value="Bank Transfer">Bank Transfer</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-bold text-cyan-300 uppercase tracking-wider mb-1.5 flex items-center justify-between">
                <span>Transaction ID *</span>
                <span class="text-[10px] text-amber-400 font-mono">Req. for Verification</span>
              </label>
              <input type="text" name="transactionId" required 
                     placeholder="e.g. BKASH-9X82M7"
                     class="w-full bg-slate-900 border border-cyan-500/50 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm font-mono text-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-500/30 transition-all uppercase" />
            </div>
          </div>

          <div class="text-[11px] text-slate-400 flex items-center gap-1.5 pt-1">
            <svg class="w-4 h-4 text-cyan-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span>Paid registrations are set to <strong>'Pending'</strong> status until verified by Admin.</span>
          </div>
        </div>
      <% else { %>
        <div class="p-3.5 rounded-xl bg-emerald-950/60 border border-emerald-500/30 flex items-center justify-between text-xs text-emerald-300 shadow-md">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-emerald-400"></span>
            <span><strong>Free Event:</strong> Immediate ticket pass generation upon submission.</span>
          </div>
          <span class="font-extrabold bg-emerald-900/80 px-2.5 py-1 rounded-lg text-emerald-200 uppercase text-[10px]">
            FREE
          </span>
        </div>
      <% } %>

      <!-- Google Sheets Auto-sync Note -->
      <div class="bg-slate-950/80 p-3 rounded-xl border border-slate-800 text-[11px] text-slate-400 flex items-center gap-2">
        <svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span>Data will be automatically appended to Google Sheet tab: <strong class="text-emerald-300">'<%= event.sheetTabName %>'</strong></span>
      </div>

      <!-- Submit Button -->
      <div class="pt-4">
        <button type="submit" 
                class="w-full font-extrabold text-sm py-4 rounded-xl transition-all shadow-lg active:scale-95 cursor-pointer <%= isWaitlist ? 'bg-gradient-to-r from-amber-500 to-orange-600 hover:from-amber-400 hover:to-orange-500 text-slate-950 shadow-amber-500/20' : 'bg-gradient-to-r from-cyan-400 via-sky-500 to-indigo-600 hover:from-cyan-300 hover:to-indigo-500 text-slate-950 shadow-cyan-500/25' %>">
          <%= isWaitlist ? 'Submit Waitlist Application' : i18n.registration.submitBtn %>
        </button>
      </div>

    </form>

  </div>

</div>

<%- include('partials/footer') %>
