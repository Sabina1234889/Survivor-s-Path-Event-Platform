<%- include('partials/header') %>

<div class="max-w-7xl mx-auto space-y-8 py-4">

  <!-- Header Section with 3D Glass Badge -->
  <div class="text-center space-y-4">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-950/60 border border-cyan-500/30 text-cyan-400 text-xs font-semibold tracking-wide uppercase shadow-lg shadow-cyan-500/10">
      <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
      </svg>
      <span>Interactive Event Calendar & Registration Hub</span>
    </div>

    <h1 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white via-slate-100 to-cyan-300">
      <%= i18n.events.title %>
    </h1>

    <p class="text-slate-400 text-sm sm:text-base max-w-2xl mx-auto leading-relaxed">
      Explore scheduled youth summits, innovation hackathons, and resilience workshops. Use the 3D Glassmorphism calendar to filter events by date or browse by category.
    </p>
  </div>

  <!-- Search & Category Filter Toolbar -->
  <div class="glass-panel p-3 sm:p-4 rounded-2xl shadow-xl flex flex-col md:flex-row items-center justify-between gap-4">
    
    <!-- Search Input -->
    <div class="relative w-full md:w-80">
      <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-cyan-400">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <input 
        type="text" 
        id="eventsSearchInput" 
        placeholder="Search event title, topic or venue..." 
        class="w-full pl-10 pr-4 py-2.5 bg-slate-950/60 border border-slate-700/80 focus:border-cyan-400 rounded-xl text-xs text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/20 transition-all"
      />
    </div>

    <!-- Filter Buttons & Active Filter Pill -->
    <div class="flex items-center gap-3 w-full md:w-auto flex-wrap justify-end">
      
      <!-- Category Filter Dropdown -->
      <select 
        id="categoryFilterSelect" 
        class="bg-slate-950/60 border border-slate-700/80 text-xs font-semibold text-slate-200 rounded-xl px-3 py-2.5 focus:border-cyan-400 focus:outline-none transition-all cursor-pointer"
      >
        <option value="ALL">All Categories</option>
        <option value="Civic Action">Civic Action</option>
        <option value="Leadership">Leadership</option>
        <option value="Hackathon">Hackathon</option>
        <option value="Workshop">Workshop</option>
      </select>

      <!-- Clear Date Filter Button (Hidden when no date filter active) -->
      <button 
        type="button" 
        id="clearDateFilterBtn" 
        class="hidden items-center gap-1.5 bg-cyan-950/80 hover:bg-cyan-900 border border-cyan-400/50 text-cyan-300 text-xs font-bold px-3 py-2.5 rounded-xl transition-all shadow-md"
        onclick="clearDateFilter()"
      >
        <svg class="w-3.5 h-3.5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        <span id="activeDateLabel">Filter Active</span>
      </button>

    </div>
  </div>

  <!-- Active Date Filter Banner -->
  <div id="activeFilterNotice" class="hidden glass-panel p-4 rounded-xl border border-cyan-500/40 bg-cyan-950/30 text-cyan-300 text-xs flex items-center justify-between">
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4 text-cyan-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <span>Showing events scheduled for <strong id="filterDateDisplay" class="text-white font-mono">2026-07-28</strong></span>
    </div>
    <button onclick="clearDateFilter()" class="text-cyan-400 underline hover:text-white font-semibold">Show All Dates</button>
  </div>

  <!-- Main Two-Column Split Layout -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

    <!-- SIDE 1: Interactive 3D Glassmorphism Calendar (5 Cols) -->
    <div class="lg:col-span-5 space-y-4">
      <div class="card-3d-wrap">
        <div class="card-3d glass-panel p-5 sm:p-6 rounded-3xl border border-white/15 bg-slate-900/80 backdrop-blur-xl shadow-2xl relative overflow-hidden">
          
          <!-- Calendar Title & Month Navigation Bar -->
          <div class="flex items-center justify-between mb-5">
            <div>
              <span class="text-[10px] font-extrabold uppercase tracking-widest text-cyan-400 block">Interactive Calendar</span>
              <h2 id="calendarMonthTitle" class="text-lg font-black text-white">July 2026</h2>
            </div>

            <!-- Prev / Next Navigation Controls -->
            <div class="flex items-center gap-1.5">
              <button 
                type="button" 
                onclick="changeCalendarMonth(-1)"
                class="w-8 h-8 rounded-xl bg-slate-950/80 hover:bg-slate-800 border border-slate-700/60 flex items-center justify-center text-slate-300 hover:text-cyan-400 transition-all cursor-pointer"
                title="Previous Month"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
              </button>
              <button 
                type="button" 
                onclick="jumpToToday()"
                class="px-2.5 py-1.5 text-[10px] font-bold uppercase tracking-wider bg-slate-950/80 hover:bg-slate-800 border border-slate-700/60 text-cyan-400 rounded-xl transition-all cursor-pointer"
              >
                Today
              </button>
              <button 
                type="button" 
                onclick="changeCalendarMonth(1)"
                class="w-8 h-8 rounded-xl bg-slate-950/80 hover:bg-slate-800 border border-slate-700/60 flex items-center justify-center text-slate-300 hover:text-cyan-400 transition-all cursor-pointer"
                title="Next Month"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </button>
            </div>
          </div>

          <!-- Weekday Headers Grid -->
          <div class="grid grid-cols-7 gap-1 text-center text-[11px] font-bold uppercase tracking-wider text-slate-400 mb-2 border-b border-slate-800/80 pb-2">
            <span>Sun</span>
            <span>Mon</span>
            <span>Tue</span>
            <span>Wed</span>
            <span>Thu</span>
            <span>Fri</span>
            <span>Sat</span>
          </div>

          <!-- Calendar Days Grid Container -->
          <div id="calendarGrid" class="grid grid-cols-7 gap-1.5">
            <!-- Dynamic Calendar Cells rendered via JavaScript -->
          </div>

          <!-- Calendar Legend & Summary -->
          <div class="mt-6 pt-4 border-t border-slate-800/80 flex items-center justify-between text-xs text-slate-400 flex-wrap gap-2">
            <div class="flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-cyan-400 shadow-sm shadow-cyan-400/80 animate-pulse"></span>
              <span class="text-[11px]">Event Scheduled</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-purple-500 border border-purple-300"></span>
              <span class="text-[11px]">Today</span>
            </div>
            <div class="text-[11px] text-cyan-300/80 font-mono font-semibold" id="monthEventsCountLabel">
              0 events this month
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- SIDE 2: Event Lists - "This Month's Events" & "Upcoming Events" (7 Cols) -->
    <div class="lg:col-span-7 space-y-8">

      <!-- SECTION 1: This Month's Events -->
      <div id="thisMonthEventsSection" class="space-y-4">
        
        <div class="flex items-center justify-between border-b border-slate-800 pb-3">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-cyan-400 shadow-md shadow-cyan-400/50"></span>
            <h2 class="text-xl sm:text-2xl font-black text-white tracking-tight">This Month's Events</h2>
          </div>
          <span id="thisMonthBadgeCount" class="text-xs font-bold font-mono bg-cyan-950/80 border border-cyan-500/30 text-cyan-300 px-3 py-1 rounded-full">
            0 Scheduled
          </span>
        </div>

        <!-- Container for This Month's Event Cards -->
        <div id="thisMonthEventsContainer" class="space-y-4">
          <!-- Dynamically populated by JS -->
        </div>

      </div>

      <!-- SECTION 2: Upcoming Events -->
      <div id="upcomingEventsSection" class="space-y-4 pt-2">
        
        <div class="flex items-center justify-between border-b border-slate-800 pb-3">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-purple-500 shadow-md shadow-purple-500/50"></span>
            <h2 class="text-xl sm:text-2xl font-black text-white tracking-tight">Upcoming Events</h2>
          </div>
          <span id="upcomingBadgeCount" class="text-xs font-bold font-mono bg-purple-950/80 border border-purple-500/30 text-purple-300 px-3 py-1 rounded-full">
            0 Scheduled
          </span>
        </div>

        <!-- Container for Upcoming Event Cards -->
        <div id="upcomingEventsContainer" class="space-y-4">
          <!-- Dynamically populated by JS -->
        </div>

      </div>

    </div>

  </div>

</div>

<!-- Pass Backend Events Array to Frontend Script -->
<script>
  window.EVENTS_DATA = <%- JSON.stringify(events) %>;
  window.CURRENT_LANG = "<%= lang %>";
</script>

<!-- Vanilla JavaScript for Interactive Calendar & Dynamic Filtering -->
<script>
  // Initial State
  // Default to July 2026 (or current date if matching system date)
  const initialDate = new Date('2026-07-22');
  let currentCalYear = initialDate.getFullYear();
  let currentCalMonth = initialDate.getMonth(); // 0 = Jan, 6 = July
  
  let activeSelectedDateStr = null; // YYYY-MM-DD when day clicked
  let activeCategory = 'ALL';
  let activeSearchQuery = '';

  const MONTH_NAMES = [
    'January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December'
  ];

  // Helper: Format Date YYYY-MM-DD
  function formatDateKey(year, monthZeroIdx, dayNum) {
    const mm = String(monthZeroIdx + 1).padStart(2, '0');
    const dd = String(dayNum).padStart(2, '0');
    return `${year}-${mm}-${dd}`;
  }

  // Initialize Calendar & Lists on DOM Load
  document.addEventListener('DOMContentLoaded', () => {
    initCalendar();
    renderEventLists();

    // Event listeners for search & category filters
    document.getElementById('eventsSearchInput')?.addEventListener('input', (e) => {
      activeSearchQuery = e.target.value.trim().toLowerCase();
      renderEventLists();
    });

    document.getElementById('categoryFilterSelect')?.addEventListener('change', (e) => {
      activeCategory = e.target.value;
      renderEventLists();
    });
  });

  // Calendar Navigation Controls
  function changeCalendarMonth(delta) {
    currentCalMonth += delta;
    if (currentCalMonth < 0) {
      currentCalMonth = 11;
      currentCalYear--;
    } else if (currentCalMonth > 11) {
      currentCalMonth = 0;
      currentCalYear++;
    }
    initCalendar();
  }

  function jumpToToday() {
    currentCalYear = 2026;
    currentCalMonth = 6; // July
    activeSelectedDateStr = null;
    hideDateFilterNotice();
    initCalendar();
    renderEventLists();
  }

  function clearDateFilter() {
    activeSelectedDateStr = null;
    hideDateFilterNotice();
    initCalendar();
    renderEventLists();
  }

  function hideDateFilterNotice() {
    const notice = document.getElementById('activeFilterNotice');
    const btn = document.getElementById('clearDateFilterBtn');
    if (notice) notice.classList.add('hidden');
    if (btn) btn.classList.add('hidden');
  }

  function showDateFilterNotice(dateStr) {
    const notice = document.getElementById('activeFilterNotice');
    const btn = document.getElementById('clearDateFilterBtn');
    const display = document.getElementById('filterDateDisplay');
    const label = document.getElementById('activeDateLabel');

    if (display) display.textContent = dateStr;
    if (label) label.textContent = `Date: ${dateStr}`;
    if (notice) notice.classList.remove('hidden');
    if (btn) btn.classList.remove('hidden');
  }

  // Render Vanilla JS Interactive Glassmorphism Calendar
  function initCalendar() {
    const monthTitle = document.getElementById('calendarMonthTitle');
    const grid = document.getElementById('calendarGrid');
    const monthEventsCountLabel = document.getElementById('monthEventsCountLabel');

    if (!grid) return;

    if (monthTitle) {
      monthTitle.textContent = `${MONTH_NAMES[currentCalMonth]} ${currentCalYear}`;
    }

    grid.innerHTML = '';

    // First day of selected month & total days in month
    const firstDayIdx = new Date(currentCalYear, currentCalMonth, 1).getDay(); // 0 = Sun
    const totalDaysInMonth = new Date(currentCalYear, currentCalMonth + 1, 0).getDate();

    // Map scheduled events by date key 'YYYY-MM-DD'
    const eventDatesMap = {};
    let countInMonth = 0;

    (window.EVENTS_DATA || []).forEach(evt => {
      const evtDate = evt.date; // e.g. "2026-07-28"
      if (!eventDatesMap[evtDate]) {
        eventDatesMap[evtDate] = [];
      }
      eventDatesMap[evtDate].push(evt);

      const [y, m] = evtDate.split('-').map(Number);
      if (y === currentCalYear && m === (currentCalMonth + 1)) {
        countInMonth++;
      }
    });

    if (monthEventsCountLabel) {
      monthEventsCountLabel.textContent = `${countInMonth} event${countInMonth === 1 ? '' : 's'} scheduled in ${MONTH_NAMES[currentCalMonth]}`;
    }

    // Render leading empty padding cells from previous month
    for (let i = 0; i < firstDayIdx; i++) {
      const emptyCell = document.createElement('div');
      emptyCell.className = 'calendar-day-cell other-month';
      grid.appendChild(emptyCell);
    }

    // Render days of the current month
    const todayStr = '2026-07-22';

    for (let day = 1; day <= totalDaysInMonth; day++) {
      const dayKey = formatDateKey(currentCalYear, currentCalMonth, day);
      const hasEvents = !!eventDatesMap[dayKey];
      const isToday = (dayKey === todayStr);
      const isSelected = (dayKey === activeSelectedDateStr);

      const dayCell = document.createElement('div');
      let cellClasses = ['calendar-day-cell'];

      if (hasEvents) cellClasses.push('has-event');
      if (isToday) cellClasses.push('today');
      if (isSelected) cellClasses.push('selected-day');

      dayCell.className = cellClasses.join(' ');
      
      dayCell.innerHTML = `
        <span class="text-xs font-bold ${isToday ? 'text-purple-300' : 'text-slate-200'}">${day}</span>
      `;

      if (hasEvents) {
        dayCell.title = `${eventDatesMap[dayKey].length} Event(s) on ${dayKey}: ${eventDatesMap[dayKey].map(e => e.titleEn).join(', ')}`;
      }

      // Day Click Handler: Filter events list to clicked date!
      dayCell.addEventListener('click', () => {
        if (activeSelectedDateStr === dayKey) {
          // Toggle off if clicked twice
          clearDateFilter();
        } else {
          activeSelectedDateStr = dayKey;
          showDateFilterNotice(dayKey);
          initCalendar();
          renderEventLists();
        }
      });

      grid.appendChild(dayCell);
    }
  }

  // Render 3D Glassmorphism Event Cards into "This Month's Events" & "Upcoming Events"
  function renderEventLists() {
    const thisMonthContainer = document.getElementById('thisMonthEventsContainer');
    const upcomingContainer = document.getElementById('upcomingEventsContainer');
    const thisMonthBadgeCount = document.getElementById('thisMonthBadgeCount');
    const upcomingBadgeCount = document.getElementById('upcomingBadgeCount');

    if (!thisMonthContainer || !upcomingContainer) return;

    thisMonthContainer.innerHTML = '';
    upcomingContainer.innerHTML = '';

    const allEvents = window.EVENTS_DATA || [];
    const isBn = (window.CURRENT_LANG === 'bn');

    // Current Month reference string "2026-07"
    const currentMonthKey = `${currentCalYear}-${String(currentCalMonth + 1).padStart(2, '0')}`;

    const thisMonthList = [];
    const upcomingList = [];

    allEvents.forEach(evt => {
      // 1. Search Query Filter
      if (activeSearchQuery) {
        const titleMatch = (evt.titleEn || '').toLowerCase().includes(activeSearchQuery) || 
                           (evt.titleBn || '').toLowerCase().includes(activeSearchQuery);
        const locMatch = (evt.locationEn || '').toLowerCase().includes(activeSearchQuery) || 
                         (evt.locationBn || '').toLowerCase().includes(activeSearchQuery);
        const catMatch = (evt.category || '').toLowerCase().includes(activeSearchQuery);
        if (!titleMatch && !locMatch && !catMatch) return;
      }

      // 2. Category Filter
      if (activeCategory !== 'ALL' && evt.category !== activeCategory) {
        return;
      }

      // 3. Date Filter (If specific date selected from calendar)
      if (activeSelectedDateStr && evt.date !== activeSelectedDateStr) {
        return;
      }

      // Categorize into "This Month" vs "Upcoming"
      const eventMonthKey = evt.date.substring(0, 7); // e.g. "2026-07" or "2026-08"

      if (eventMonthKey === currentMonthKey) {
        thisMonthList.push(evt);
      } else if (eventMonthKey > currentMonthKey) {
        upcomingList.push(evt);
      } else {
        // Past events can go to this month if date filter matched
        thisMonthList.push(evt);
      }
    });

    // Update Counts
    if (thisMonthBadgeCount) thisMonthBadgeCount.textContent = `${thisMonthList.length} Event${thisMonthList.length === 1 ? '' : 's'}`;
    if (upcomingBadgeCount) upcomingBadgeCount.textContent = `${upcomingList.length} Event${upcomingList.length === 1 ? '' : 's'}`;

    // Render "This Month's Events"
    if (thisMonthList.length === 0) {
      thisMonthContainer.innerHTML = `
        <div class="glass-panel p-6 text-center text-slate-400 text-xs rounded-2xl border border-slate-800">
          No events found for ${MONTH_NAMES[currentCalMonth]} matching your filters.
        </div>
      `;
    } else {
      thisMonthList.forEach(evt => {
        thisMonthContainer.appendChild(createEventGlassCard(evt, isBn));
      });
    }

    // Render "Upcoming Events"
    if (upcomingList.length === 0) {
      upcomingContainer.innerHTML = `
        <div class="glass-panel p-6 text-center text-slate-400 text-xs rounded-2xl border border-slate-800">
          No upcoming events scheduled beyond ${MONTH_NAMES[currentCalMonth]}.
        </div>
      `;
    } else {
      upcomingList.forEach(evt => {
        upcomingContainer.appendChild(createEventGlassCard(evt, isBn));
      });
    }
  }

  // Helper Function: Create 3D Glassmorphism Card Element with Hero Event Poster
  function createEventGlassCard(event, isBn) {
    const spotsLeft = Math.max(0, event.capacity - event.currentRegistrations);
    const isWaitlist = spotsLeft === 0;

    const title = isBn ? event.titleBn : event.titleEn;
    const desc = isBn ? event.descriptionBn : event.descriptionEn;
    const location = isBn ? event.locationBn : event.locationEn;
    const posterUrl = event.imageBg || event.poster_url || 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?auto=format&fit=crop&w=1200&q=80';

    const cardWrap = document.createElement('div');
    cardWrap.className = 'card-3d-wrap';

    cardWrap.innerHTML = `
      <div class="card-3d glass-panel p-4 sm:p-5 rounded-3xl border border-white/10 hover:border-cyan-400/50 bg-slate-900/80 backdrop-blur-xl shadow-xl hover:shadow-cyan-500/20 transition-all duration-300 relative overflow-hidden group">
        
        <!-- Hero Event Poster Banner with Glass Overlay -->
        <div class="relative w-full h-44 sm:h-52 rounded-2xl overflow-hidden border border-white/10 shadow-lg mb-4 group-hover:scale-[1.01] transition-transform duration-300">
          <img 
            src="${posterUrl}" 
            alt="${title}"
            class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            onerror="this.src='https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=1200&q=80'"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/30 to-transparent"></div>

          <!-- Floating Category & Capacity Badges on Poster -->
          <div class="absolute top-3 left-3 right-3 flex items-center justify-between gap-2 z-10 flex-wrap">
            <span class="px-3 py-1 rounded-full bg-slate-950/80 backdrop-blur-md border border-cyan-400/40 text-cyan-300 text-[10px] sm:text-[11px] font-extrabold uppercase tracking-wider shadow-md">
              ${event.category}
            </span>

            ${isWaitlist ? `
              <span class="px-3 py-1 rounded-full bg-amber-950/90 backdrop-blur-md border border-amber-500/50 text-amber-300 text-[10px] sm:text-[11px] font-extrabold flex items-center gap-1.5 shadow-md">
                <span class="w-2 h-2 rounded-full bg-amber-400 animate-ping"></span>
                Waitlist Mode
              </span>
            ` : `
              <span class="px-3 py-1 rounded-full bg-emerald-950/90 backdrop-blur-md border border-emerald-500/50 text-emerald-300 text-[10px] sm:text-[11px] font-extrabold flex items-center gap-1.5 shadow-md">
                <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
                ${spotsLeft} spots left
              </span>
            `}
          </div>

          <!-- Organizer Floating Label on Poster Bottom Left -->
          <div class="absolute bottom-2.5 left-3 z-10 text-[10px] font-semibold text-slate-300/90 flex items-center gap-1 bg-slate-950/70 px-2.5 py-1 rounded-md backdrop-blur-sm border border-white/5">
            <svg class="w-3 h-3 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            <span class="truncate max-w-[200px]">${event.organizer || "Survivor's Path Network"}</span>
          </div>
        </div>

        <!-- Background Ambient Color Gradient Accent -->
        <div class="absolute -bottom-16 -right-16 w-36 h-36 bg-gradient-to-br ${event.accentColor || 'from-cyan-600 to-indigo-900'} opacity-20 rounded-full blur-2xl group-hover:opacity-40 transition-opacity"></div>

        <div class="relative z-10 space-y-3">

          <!-- Title & Description -->
          <div class="space-y-1">
            <h3 class="text-lg sm:text-xl font-black text-white group-hover:text-cyan-300 transition-colors leading-snug">
              ${title}
            </h3>
            <p class="text-slate-400 text-xs sm:text-sm line-clamp-2 leading-relaxed">
              ${desc}
            </p>
          </div>

          <!-- Date, Time & Venue Details -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs text-slate-300 pt-2 border-t border-slate-800/80">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-cyan-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              <span class="font-bold text-slate-100">${event.date}</span> • <span class="text-slate-400">${event.time}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-purple-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.242-4.243a8 8 0 1111.314 0z"></path></svg>
              <span class="truncate">${location}</span>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="flex items-center gap-3 pt-2">
            <a 
              href="/events/${event.slug}" 
              class="flex-1 bg-slate-950/80 hover:bg-slate-800 text-slate-200 hover:text-white font-bold text-xs py-2.5 rounded-xl transition-all border border-slate-700 text-center"
            >
              View Details
            </a>
            <a 
              href="/events/${event.slug}/register" 
              class="flex-1 bg-gradient-to-r ${isWaitlist ? 'from-amber-500 to-orange-600 hover:from-amber-400 hover:to-orange-500 text-slate-950' : 'from-cyan-500 to-indigo-600 hover:from-cyan-400 hover:to-indigo-500 text-slate-950'} font-black text-xs py-2.5 rounded-xl transition-all shadow-md text-center active:scale-95"
            >
              ${isWaitlist ? 'Join Waitlist' : 'Register Now'}
            </a>
          </div>

        </div>
      </div>
    `;

    return cardWrap;
  }
</script>

