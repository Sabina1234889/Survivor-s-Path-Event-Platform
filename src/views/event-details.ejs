<%- include('partials/header') %>

<% 
  const eventTitle = lang === 'bn' ? event.titleBn : event.titleEn;
  const eventDesc = lang === 'bn' ? event.descriptionBn : event.descriptionEn;
  const eventLoc = lang === 'bn' ? event.locationBn : event.locationEn;
  const fillPercentage = Math.min(100, Math.round((event.currentRegistrations / event.capacity) * 100));
%>

<div class="max-w-4xl mx-auto space-y-8 py-4">

  <!-- Back Link -->
  <a href="/events" class="inline-flex items-center gap-2 text-xs font-bold text-cyan-400 hover:text-cyan-300 transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
    <span><%= i18n.ticket.backToEvents %></span>
  </a>

  <!-- 3D Glass Header Banner -->
  <div class="glass-panel p-8 rounded-3xl relative overflow-hidden border border-cyan-500/30">
    
    <div class="relative z-10 space-y-4">
      <div class="flex flex-wrap items-center gap-3">
        <span class="bg-cyan-500/20 text-cyan-300 text-xs font-bold px-3 py-1 rounded-md border border-cyan-400/30">
          <%= event.category %>
        </span>
        <span class="text-xs font-semibold text-slate-400">
          <%= i18n.events.organizer %>: <strong class="text-white"><%= event.organizer %></strong>
        </span>
      </div>

      <h1 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">
        <%= eventTitle %>
      </h1>

      <p class="text-sm sm:text-base text-slate-300 leading-relaxed max-w-2xl">
        <%= eventDesc %>
      </p>

      <!-- Date, Time, Location Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4">
        <div class="bg-slate-950/60 p-4 rounded-xl border border-slate-800 flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-cyan-500/10 border border-cyan-500/30 flex items-center justify-center text-cyan-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          </div>
          <div>
            <div class="text-[11px] text-slate-400 uppercase font-semibold"><%= i18n.events.dateTime %></div>
            <div class="text-xs font-bold text-white"><%= event.date %> (<%= event.time %>)</div>
          </div>
        </div>

        <div class="bg-slate-950/60 p-4 rounded-xl border border-slate-800 flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 border border-purple-500/30 flex items-center justify-center text-purple-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
          </div>
          <div>
            <div class="text-[11px] text-slate-400 uppercase font-semibold"><%= i18n.events.location %></div>
            <div class="text-xs font-bold text-white"><%= eventLoc %></div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Capacity & Registration Callout Panel -->
  <div class="glass-panel p-8 rounded-3xl space-y-6">
    
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <h3 class="text-lg font-bold text-white">Event Seat Allocation & Capacity</h3>
        <p class="text-xs text-slate-400 mt-0.5">
          Real-time tracking. When capacity (<%= event.capacity %>) is met, new registrants automatically receive <strong class="text-amber-400">Waitlist Status</strong>.
        </p>
      </div>

      <% if (isFull) { %>
        <span class="self-start sm:self-auto bg-amber-950/90 text-amber-300 text-xs font-extrabold px-3.5 py-1.5 rounded-lg border border-amber-500/40">
          WAITLIST ACTIVE (<%= event.currentRegistrations %>/<%= event.capacity %>)
        </span>
      <% } else { %>
        <span class="self-start sm:self-auto bg-emerald-950/90 text-emerald-300 text-xs font-extrabold px-3.5 py-1.5 rounded-lg border border-emerald-500/40">
          <%= spotsLeft %> SPOTS REMAINING
        </span>
      <% } %>
    </div>

    <!-- Progress Bar -->
    <div class="space-y-2">
      <div class="w-full h-3 bg-slate-950 rounded-full overflow-hidden p-0.5 border border-slate-800">
        <div class="h-full rounded-full transition-all duration-500 <%= isFull ? 'bg-amber-500' : 'bg-gradient-to-r from-cyan-400 to-emerald-400' %>" 
             style="width: <%= fillPercentage %>%"></div>
      </div>
      <div class="flex justify-between text-xs font-mono text-slate-400">
        <span>Registered: <%= event.currentRegistrations %></span>
        <span>Limit: <%= event.capacity %></span>
      </div>
    </div>

    <!-- Google Sheet Sync info -->
    <div class="bg-slate-950/80 p-4 rounded-xl border border-slate-800/80 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        <div>
          <div class="text-xs font-bold text-white">Google Sheet Target Tab</div>
          <div class="text-[11px] text-slate-400">Submissions append to tab: <strong class="text-emerald-300">'<%= event.sheetTabName %>'</strong></div>
        </div>
      </div>
      <% if (currentUser && (currentUser.role === 'admin' || currentUser.email === 'mdanontosunny1068@gmail.com')) { %>
        <a href="/admin/sheets" class="text-xs text-cyan-400 hover:underline font-semibold">Inspect Sheet</a>
      <% } %>
    </div>

    <!-- Register Button -->
    <div class="pt-4">
      <a href="/events/<%= event.slug %>/register" 
         class="w-full block text-center font-extrabold text-sm py-4 rounded-xl transition-all shadow-lg active:scale-95 <%= isFull ? 'bg-gradient-to-r from-amber-500 to-orange-600 text-slate-950 shadow-amber-500/20' : 'bg-gradient-to-r from-cyan-400 via-sky-500 to-indigo-600 text-slate-950 shadow-cyan-500/25' %>">
        <%= isFull ? 'Register for Priority Waitlist' : i18n.events.getTicket %>
      </a>
    </div>

  </div>

</div>

<%- include('partials/footer') %>
