<%- include('partials/header') %>

<div class="max-w-5xl mx-auto py-6">

  <!-- Split-Screen 3D Glassmorphism Container -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
    
    <!-- Left Column: Platform Branding & Google Sheets DB Guarantee -->
    <div class="lg:col-span-5 glass-panel p-8 rounded-3xl border border-cyan-500/30 flex flex-col justify-between space-y-6 relative overflow-hidden shadow-2xl">
      <div class="space-y-4 z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-950/80 border border-cyan-500/40 text-[11px] font-bold text-cyan-300 uppercase tracking-wider">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-ping"></span>
          <span>Youth Registration Portal</span>
        </div>

        <h2 class="text-2xl sm:text-3xl font-black text-white tracking-tight leading-tight">
          Join the <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-indigo-400">Survivor's Path</span> Movement
        </h2>

        <p class="text-xs text-slate-300 leading-relaxed">
          Create your account today to access transformational youth summits, workshops, hackathons, and 3D holographic digital gate passes.
        </p>

        <!-- Highlights & Database Integration Notice -->
        <div class="space-y-3 pt-2">
          <div class="flex items-center gap-3 p-3 rounded-2xl bg-slate-900/80 border border-slate-800">
            <div class="p-2 rounded-xl bg-emerald-500/20 text-emerald-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div>
              <div class="text-xs font-bold text-white">Google Sheets Database Storage</div>
              <div class="text-[10px] text-slate-400">Your profile details are auto-synced to Google Sheet tab "Users".</div>
            </div>
          </div>

          <div class="flex items-center gap-3 p-3 rounded-2xl bg-slate-900/80 border border-slate-800">
            <div class="p-2 rounded-xl bg-cyan-500/20 text-cyan-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </div>
            <div>
              <div class="text-xs font-bold text-white">Email Uniqueness Integrity</div>
              <div class="text-[10px] text-slate-400">Unique email validation prevents duplicate registrations and ticket conflicts.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Footer Note -->
      <div class="pt-4 border-t border-slate-800/80 z-10">
        <div class="text-[11px] text-slate-400 flex items-center gap-2">
          <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span>Need help? Contact support or speak with an organizer.</span>
        </div>
      </div>
    </div>

    <!-- Right Column: Glassmorphism Sign Up Form -->
    <div class="lg:col-span-7 glass-panel p-8 sm:p-10 rounded-3xl border border-cyan-500/30 space-y-6 shadow-2xl">
      
      <!-- Smart Post-Signup Return Alert -->
      <% if (typeof redirectUrl !== 'undefined' && redirectUrl && redirectUrl !== '/events' && redirectUrl !== '/') { %>
        <div class="p-4 rounded-2xl bg-cyan-950/90 border border-cyan-500/60 flex items-start gap-3 shadow-xl">
          <div class="p-2 rounded-xl bg-cyan-500/20 text-cyan-400 flex-shrink-0">
            <svg class="w-5 h-5 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div>
            <div class="text-xs font-bold text-cyan-300">Seamless Registration Active</div>
            <div class="text-[11px] text-slate-300 mt-0.5">
              Create an account to complete your event pass request. You will return directly to your event registration page.
            </div>
          </div>
        </div>
      <% } %>

      <!-- Error Notification Alert -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="p-4 rounded-2xl bg-rose-950/90 border border-rose-500/60 text-rose-200 text-xs font-bold flex items-center gap-3 shadow-xl">
          <svg class="w-5 h-5 text-rose-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <div class="space-y-1 border-b border-slate-800 pb-4">
        <h1 class="text-2xl font-black text-white tracking-tight">
          Create Your Youth Account
        </h1>
        <p class="text-xs text-slate-400">
          Fill out your details below to set up your account and sync with Google Sheets.
        </p>
      </div>

      <!-- Auth Signup Form -->
      <form action="/signup" method="POST" class="space-y-4">
        <input type="hidden" name="redirect" value="<%= redirectUrl %>" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
              Full Name *
            </label>
            <input type="text" name="name" required placeholder="e.g. Anika Rahman"
                   class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none transition-all focus:ring-2 focus:ring-cyan-500/30" />
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
              Email Address *
            </label>
            <input type="email" name="email" required placeholder="e.g. anika@example.com"
                   class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none transition-all focus:ring-2 focus:ring-cyan-500/30" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
              Password *
            </label>
            <input type="password" name="password" required placeholder="••••••••"
                   class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none transition-all focus:ring-2 focus:ring-cyan-500/30" />
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
              Phone Number
            </label>
            <input type="tel" name="phone" placeholder="+880 1700-000000"
                   class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none transition-all focus:ring-2 focus:ring-cyan-500/30" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
              Institute / Organization
            </label>
            <input type="text" name="organization" placeholder="e.g. Dhaka University Youth Club"
                   class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none transition-all focus:ring-2 focus:ring-cyan-500/30" />
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
              Address / Location
            </label>
            <input type="text" name="address" placeholder="e.g. Dhanmondi, Dhaka"
                   class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none transition-all focus:ring-2 focus:ring-cyan-500/30" />
          </div>
        </div>

        <button type="submit" 
                class="w-full bg-gradient-to-r from-cyan-400 via-sky-500 to-indigo-600 hover:from-cyan-300 hover:to-indigo-500 text-slate-950 font-black text-sm py-4 rounded-xl shadow-lg shadow-cyan-500/25 transition-all cursor-pointer active:scale-95 mt-2">
          Register & Create Account →
        </button>
      </form>

      <!-- Toggle to Login Page -->
      <div class="pt-4 text-center border-t border-slate-800/80">
        <p class="text-xs text-slate-400">
          Already registered? 
          <a href="/login?redirect=<%= encodeURIComponent(redirectUrl) %>" class="font-bold text-cyan-400 hover:text-cyan-300 hover:underline">
            Sign In to Existing Account →
          </a>
        </p>
      </div>

    </div>

  </div>

</div>

<%- include('partials/footer') %>
