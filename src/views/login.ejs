<%- include('partials/header') %>

<div class="max-w-5xl mx-auto py-6">

  <!-- Split-Screen 3D Glassmorphism Container -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
    
    <!-- Left Column: Branding, Platform Features & Demo Shortcuts -->
    <div class="lg:col-span-5 glass-panel p-8 rounded-3xl border border-cyan-500/30 flex flex-col justify-between space-y-6 relative overflow-hidden shadow-2xl">
      <div class="space-y-4 z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-950/80 border border-cyan-500/40 text-[11px] font-bold text-cyan-300 uppercase tracking-wider">
          <span class="w-2 h-2 rounded-full bg-cyan-400 animate-ping"></span>
          <span>Youth Identity & Portal</span>
        </div>

        <h2 class="text-2xl sm:text-3xl font-black text-white tracking-tight leading-tight">
          Welcome Back to <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-emerald-400">Survivor's Path</span>
        </h2>

        <p class="text-xs text-slate-300 leading-relaxed">
          Sign in to access your digital pass wallet, manage event registrations, and sync records directly to our Google Sheets youth database.
        </p>

        <!-- Feature Badges -->
        <div class="space-y-3 pt-2">
          <div class="flex items-center gap-3 p-3 rounded-2xl bg-slate-900/80 border border-slate-800">
            <div class="p-2 rounded-xl bg-cyan-500/20 text-cyan-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 002 2h14a2 2 0 002-2V7a2 2 0 00-2-2H5z"></path></svg>
            </div>
            <div>
              <div class="text-xs font-bold text-white">Instant 3D Holographic Passes</div>
              <div class="text-[10px] text-slate-400">Generate scannable gate passes with unique QR codes.</div>
            </div>
          </div>

          <div class="flex items-center gap-3 p-3 rounded-2xl bg-slate-900/80 border border-slate-800">
            <div class="p-2 rounded-xl bg-emerald-500/20 text-emerald-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div>
              <div class="text-xs font-bold text-white">Google Sheets Database Sync</div>
              <div class="text-[10px] text-slate-400">User accounts and passes auto-saved to tab "Users".</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick One-Click Demo Sign-In Options -->
      <div class="space-y-3 pt-4 border-t border-slate-800 z-10">
        <div class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">
          Quick One-Click Demo Sign-In
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <form action="/login" method="POST">
            <input type="hidden" name="email" value="anika.rahman@survivorspath.org" />
            <input type="hidden" name="name" value="Anika Rahman" />
            <input type="hidden" name="redirect" value="<%= redirectUrl %>" />
            <button type="submit" class="w-full bg-slate-900 hover:bg-slate-800 text-cyan-300 border border-cyan-500/30 font-bold text-[11px] p-2.5 rounded-xl transition-all flex items-center gap-2 cursor-pointer shadow">
              <div class="w-5 h-5 rounded-full bg-cyan-400/20 flex items-center justify-center font-black text-cyan-300 text-[10px]">A</div>
              <span class="truncate">Anika (Attendee)</span>
            </button>
          </form>

          <form action="/login" method="POST">
            <input type="hidden" name="email" value="tanvir.hossain@survivorspath.org" />
            <input type="hidden" name="name" value="Tanvir Hossain" />
            <input type="hidden" name="redirect" value="<%= redirectUrl %>" />
            <button type="submit" class="w-full bg-slate-900 hover:bg-slate-800 text-purple-300 border border-purple-500/30 font-bold text-[11px] p-2.5 rounded-xl transition-all flex items-center gap-2 cursor-pointer shadow">
              <div class="w-5 h-5 rounded-full bg-purple-400/20 flex items-center justify-center font-black text-purple-300 text-[10px]">T</div>
              <span class="truncate">Tanvir (Organizer)</span>
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Right Column: Glassmorphism Login Form -->
    <div class="lg:col-span-7 glass-panel p-8 sm:p-10 rounded-3xl border border-cyan-500/30 space-y-6 shadow-2xl flex flex-col justify-center">
      
      <!-- Smart Post-Login Return Alert -->
      <% if (typeof redirectUrl !== 'undefined' && redirectUrl && redirectUrl !== '/events' && redirectUrl !== '/') { %>
        <div class="p-4 rounded-2xl bg-cyan-950/90 border border-cyan-500/60 flex items-start gap-3 shadow-xl">
          <div class="p-2 rounded-xl bg-cyan-500/20 text-cyan-400 flex-shrink-0">
            <svg class="w-5 h-5 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div>
            <div class="text-xs font-bold text-cyan-300">Seamless Post-Login Return Active</div>
            <div class="text-[11px] text-slate-300 mt-0.5">
              Please sign in to confirm your ticket pass. You will be redirected back to complete your event registration automatically.
            </div>
          </div>
        </div>
      <% } %>

      <!-- Error Notification Alert -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="p-4 rounded-2xl bg-rose-950/90 border border-rose-500/60 text-rose-200 text-xs font-bold flex items-center gap-3 shadow-xl">
          <svg class="w-5 h-5 text-rose-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <div class="space-y-1 border-b border-slate-800 pb-4">
        <h1 class="text-2xl font-black text-white tracking-tight">
          Sign In to Your Account
        </h1>
        <p class="text-xs text-slate-400">
          Enter your registered email and password to access your youth profile.
        </p>
      </div>

      <!-- Auth Login Form -->
      <form action="/login" method="POST" class="space-y-5">
        <input type="hidden" name="redirect" value="<%= redirectUrl %>" />

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-2">
            Email Address *
          </label>
          <div class="relative">
            <input type="email" name="email" required placeholder="e.g. anika.rahman@survivorspath.org"
                   value="<%= typeof email !== 'undefined' ? email : '' %>"
                   class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none transition-all focus:ring-2 focus:ring-cyan-500/30" />
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider">
              Password *
            </label>
            <span class="text-[11px] text-slate-400">Default Demo: <code class="text-cyan-300">password123</code></span>
          </div>
          <input type="password" name="password" required placeholder="••••••••"
                 class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none transition-all focus:ring-2 focus:ring-cyan-500/30" />
        </div>

        <button type="submit" 
                class="w-full bg-gradient-to-r from-cyan-400 via-sky-500 to-indigo-600 hover:from-cyan-300 hover:to-indigo-500 text-slate-950 font-black text-sm py-4 rounded-xl shadow-lg shadow-cyan-500/25 transition-all cursor-pointer active:scale-95">
          Sign In & Continue →
        </button>
      </form>

      <!-- Toggle to Sign Up Page -->
      <div class="pt-4 text-center border-t border-slate-800/80">
        <p class="text-xs text-slate-400">
          Don't have an account yet? 
          <a href="/signup?redirect=<%= encodeURIComponent(redirectUrl) %>" class="font-bold text-cyan-400 hover:text-cyan-300 hover:underline">
            Create an Account (Sign Up) →
          </a>
        </p>
      </div>

    </div>

  </div>

</div>

<%- include('partials/footer') %>
