<%- include('partials/header') %>

<div class="max-w-6xl mx-auto space-y-8 py-4">

  <!-- Toast / Notification Banner -->
  <% if (typeof msg !== 'undefined' && msg) { %>
    <div class="p-4 rounded-2xl bg-cyan-950/90 border border-cyan-500/60 text-cyan-200 text-xs font-bold flex items-center justify-between shadow-2xl shadow-cyan-950/50">
      <div class="flex items-center gap-3">
        <span class="w-3 h-3 rounded-full bg-cyan-400 animate-ping"></span>
        <span><%= msg %></span>
      </div>
      <a href="/profile" class="text-[10px] uppercase tracking-wider text-cyan-400 hover:underline">Dismiss</a>
    </div>
  <% } %>

  <!-- User Profile Header Banner -->
  <div class="glass-panel p-8 rounded-3xl border border-cyan-500/30 relative overflow-hidden shadow-2xl space-y-6">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 relative z-10">
      
      <!-- User Avatar & Identity -->
      <div class="flex items-center gap-5">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-tr from-cyan-400 via-sky-500 to-indigo-600 p-[2px] shadow-lg shadow-cyan-500/30 shrink-0">
          <div class="w-full h-full bg-slate-950 rounded-[14px] flex items-center justify-center font-black text-2xl text-cyan-300">
            <%= user.name ? user.name.charAt(0) : 'U' %>
          </div>
        </div>

        <div class="space-y-1">
          <div class="flex items-center gap-3">
            <h1 class="text-2xl font-black text-white tracking-tight">
              <%= user.name %>
            </h1>
            <span class="px-3 py-0.5 rounded-full text-[10px] font-black uppercase tracking-wider <%= user.role === 'organizer' ? 'bg-purple-950 text-purple-300 border border-purple-500/40' : 'bg-cyan-950 text-cyan-300 border border-cyan-500/40' %>">
              <%= user.role === 'organizer' ? 'Organizer' : 'Youth Member' %>
            </span>
          </div>

          <div class="text-xs text-slate-400 font-mono flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <span><%= user.email %></span>
            <span class="text-slate-600">•</span>
            <span>Registered Member</span>
          </div>
        </div>
      </div>

      <!-- Quick Ticket & Pass Statistics -->
      <div class="flex items-center gap-3">
        <div class="bg-slate-900/90 border border-slate-800 p-3.5 rounded-2xl text-center min-w-[100px]">
          <div class="text-xl font-black text-cyan-300"><%= userTickets.length %></div>
          <div class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">Total Passes</div>
        </div>

        <div class="bg-slate-900/90 border border-slate-800 p-3.5 rounded-2xl text-center min-w-[100px]">
          <div class="text-xl font-black text-emerald-400">
            <%= userTickets.filter(t => t.status === 'Confirmed' || t.status === 'Registered').length %>
          </div>
          <div class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">Confirmed</div>
        </div>

        <div class="bg-slate-900/90 border border-slate-800 p-3.5 rounded-2xl text-center min-w-[100px]">
          <div class="text-xl font-black text-amber-400">
            <%= userTickets.filter(t => t.status === 'Pending').length %>
          </div>
          <div class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">Pending</div>
        </div>
      </div>

    </div>
  </div>

  <!-- Main 2-Column Dashboard Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    
    <!-- Left Column: User Profile Edit Form -->
    <div class="lg:col-span-5 glass-panel p-6 sm:p-8 rounded-3xl border border-cyan-500/30 space-y-6 shadow-2xl h-fit">
      
      <div class="border-b border-slate-800 pb-4">
        <h2 class="text-lg font-black text-white flex items-center gap-2">
          <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          <span>Edit Profile Details</span>
        </h2>
        <p class="text-xs text-slate-400 mt-1">
          Update your phone number, organization, or address. Changes auto-sync to Google Sheets tab "Users".
        </p>
      </div>

      <form action="/profile/update" method="POST" class="space-y-4">
        
        <!-- LOCKED EMAIL FIELD (CRUCIAL RULE REQUIREMENT) -->
        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5 flex items-center justify-between">
            <span class="flex items-center gap-1.5 text-slate-400">
              <svg class="w-3.5 h-3.5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              <span>Email Address</span>
            </span>
            <span class="text-[10px] text-amber-400 font-mono font-bold bg-amber-950/80 px-2 py-0.5 rounded border border-amber-500/30">
              LOCKED / NON-EDITABLE
            </span>
          </label>
          
          <input type="email" value="<%= user.email %>" disabled
                 class="w-full bg-slate-900/90 border border-amber-500/30 rounded-xl px-4 py-3 text-xs font-mono text-amber-200/80 cursor-not-allowed opacity-75 focus:outline-none" />
          
          <p class="text-[10px] text-slate-400 mt-1 flex items-center gap-1">
            <svg class="w-3.5 h-3.5 text-amber-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span>Email is strictly locked to guarantee ticket ownership and Google Sheets record integrity.</span>
          </p>
        </div>

        <!-- Full Name -->
        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            Full Name *
          </label>
          <input type="text" name="name" value="<%= user.name %>" required
                 class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <!-- Phone Number -->
        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            Phone Number *
          </label>
          <input type="tel" name="phone" value="<%= user.phone %>" required
                 class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <!-- Institute / Organization -->
        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            Institute / Organization
          </label>
          <input type="text" name="organization" value="<%= user.organization %>"
                 class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <!-- Address / District -->
        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            Address / City
          </label>
          <input type="text" name="address" value="<%= user.address %>"
                 class="w-full bg-slate-950/90 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <button type="submit" 
                class="w-full bg-gradient-to-r from-cyan-400 to-blue-600 hover:from-cyan-300 hover:to-blue-500 text-slate-950 font-black text-xs py-3.5 rounded-xl shadow-lg shadow-cyan-500/20 transition-all cursor-pointer active:scale-95 pt-2">
          Save Profile Changes →
        </button>

      </form>

    </div>

    <!-- Right Column: My Registered Event Ticket Passes -->
    <div class="lg:col-span-7 glass-panel p-6 sm:p-8 rounded-3xl border border-cyan-500/30 space-y-6 shadow-2xl">
      
      <div class="flex items-center justify-between border-b border-slate-800 pb-4">
        <div>
          <h2 class="text-lg font-black text-white flex items-center gap-2">
            <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 002 2h14a2 2 0 002-2V7a2 2 0 00-2-2H5z"></path></svg>
            <span>My Digital Event Ticket Passes</span>
          </h2>
          <p class="text-xs text-slate-400 mt-0.5">
            Your generated event tickets, approval statuses, and gate QR entry passes.
          </p>
        </div>

        <a href="/events" class="text-xs font-bold text-cyan-400 hover:underline">
          Browse Events +
        </a>
      </div>

      <% if (userTickets.length === 0) { %>
        <div class="p-8 rounded-2xl bg-slate-950/60 border border-slate-800 text-center space-y-3">
          <div class="w-12 h-12 rounded-full bg-slate-900 mx-auto flex items-center justify-center text-slate-500">
            🎟️
          </div>
          <div class="text-xs font-bold text-slate-300">No Event Passes Found Yet</div>
          <p class="text-[11px] text-slate-400 max-w-sm mx-auto">
            You haven't registered for any youth events yet. Explore upcoming summits and workshops to claim your spot!
          </p>
          <a href="/events" class="inline-block bg-cyan-500/20 border border-cyan-500/40 text-cyan-300 font-bold text-xs px-4 py-2 rounded-xl hover:bg-cyan-500/30 transition-all">
            Explore Upcoming Youth Events
          </a>
        </div>
      <% } else { %>
        <div class="space-y-4">
          <% userTickets.forEach(ticket => { %>
            <div class="p-5 rounded-2xl bg-slate-950/80 border border-slate-800 hover:border-cyan-500/50 transition-all space-y-3">
              
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-slate-800/80 pb-3">
                <div>
                  <div class="text-[10px] font-bold font-mono text-amber-400 uppercase">TICKET ID: <%= ticket.id %></div>
                  <h3 class="text-sm font-extrabold text-white"><%= ticket.eventTitle %></h3>
                </div>

                <!-- Status Badge -->
                <div>
                  <% if (ticket.status === 'Confirmed' || ticket.status === 'Registered') { %>
                    <span class="px-2.5 py-1 rounded-lg text-[10px] font-black bg-emerald-950 text-emerald-300 border border-emerald-500/40">
                      ✓ CONFIRMED PASS
                    </span>
                  <% } else if (ticket.status === 'Pending') { %>
                    <span class="px-2.5 py-1 rounded-lg text-[10px] font-black bg-amber-950 text-amber-300 border border-amber-500/40">
                      ⏳ PENDING APPROVAL
                    </span>
                  <% } else { %>
                    <span class="px-2.5 py-1 rounded-lg text-[10px] font-black bg-rose-950 text-rose-300 border border-rose-500/40">
                      WAITLIST
                    </span>
                  <% } %>
                </div>
              </div>

              <!-- Ticket Info Grid -->
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 text-xs text-slate-300">
                <div>
                  <span class="text-[10px] text-slate-500 uppercase block">Registered On</span>
                  <span><%= new Date(ticket.registeredAt).toLocaleDateString() %></span>
                </div>

                <div>
                  <span class="text-[10px] text-slate-500 uppercase block">Payment Status</span>
                  <% if (ticket.isPaidEvent) { %>
                    <span class="font-bold text-cyan-300">৳<%= ticket.paymentAmount %> (<%= ticket.paymentStatus || 'Pending' %>)</span>
                  <% } else { %>
                    <span class="font-bold text-emerald-400">FREE ENTRY</span>
                  <% } %>
                </div>

                <div class="col-span-2 sm:col-span-1 flex items-center justify-end">
                  <a href="/tickets/<%= ticket.id %>" 
                     class="w-full sm:w-auto text-center bg-cyan-500/20 hover:bg-cyan-500/30 text-cyan-300 font-bold text-[11px] px-3.5 py-2 rounded-xl border border-cyan-500/40 transition-all">
                    View Gate Pass ↗
                  </a>
                </div>
              </div>

            </div>
          <% }) %>
        </div>
      <% } %>

    </div>

  </div>

</div>

<%- include('partials/footer') %>
