<%- include('partials/header') %>

<div class="max-w-6xl mx-auto space-y-8 py-4">

  <!-- Toast / Flash Message Notification -->
  <% if (typeof msg !== 'undefined' && msg) { %>
    <div class="p-4 rounded-2xl bg-cyan-950/90 border border-cyan-500/60 text-cyan-200 text-xs font-bold flex items-center justify-between shadow-2xl shadow-cyan-950/50">
      <div class="flex items-center gap-3">
        <span class="w-3 h-3 rounded-full bg-cyan-400 animate-ping"></span>
        <span><%= msg %></span>
      </div>
      <a href="/admin/sheets" class="text-[10px] uppercase tracking-wider text-cyan-400 hover:underline">Dismiss</a>
    </div>
  <% } %>

  <!-- Header -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-800 pb-6">
    <div>
      <h1 class="text-3xl font-extrabold text-white tracking-tight flex items-center gap-3">
        <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        <span>Admin Command & Sheets Sync Hub</span>
      </h1>
      <p class="text-xs text-slate-400 mt-1">
        Manage Registrations, Verify Payments, Issue Ticket Passes, and Broadcast Bulk Emails.
      </p>
    </div>

    <!-- Status Badge -->
    <% if (config.isConnected) { %>
      <div class="bg-emerald-950/90 text-emerald-300 border border-emerald-500/50 px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 shadow-lg">
        <span class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-ping"></span>
        <span><%= i18n.sheets.statusConnected %></span>
      </div>
    <% } else { %>
      <div class="bg-amber-950/90 text-amber-300 border border-amber-500/50 px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 shadow-lg">
        <span class="w-2.5 h-2.5 rounded-full bg-amber-400 animate-pulse"></span>
        <span><%= i18n.sheets.statusMock %></span>
      </div>
    <% } %>
  </div>

  <!-- Quick Action Grid: Make Admin & Export CSV -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <!-- 1. Make New Admin (Promote to Admin) -->
    <div class="glass-panel p-6 rounded-3xl border border-purple-500/30 space-y-4 shadow-xl lg:col-span-1">
      <div class="border-b border-slate-800 pb-3">
        <h2 class="text-base font-black text-white flex items-center gap-2">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          <span>Promote User to Admin</span>
        </h2>
        <p class="text-xs text-slate-400 mt-1">
          Enter an existing registered email address to grant full Admin Panel access.
        </p>
      </div>

      <form action="/admin/promote-user" method="POST" class="space-y-3">
        <div>
          <label class="block text-[11px] font-bold text-slate-300 uppercase tracking-wider mb-1">
            User Email Address
          </label>
          <input type="email" name="email" required placeholder="user@example.com" 
                 class="w-full bg-slate-950 border border-slate-700 focus:border-purple-400 rounded-xl px-3.5 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <button type="submit" class="w-full bg-gradient-to-r from-purple-500 to-indigo-600 hover:from-purple-400 hover:to-indigo-500 text-white font-black text-xs py-2.5 rounded-xl transition-all shadow-md active:scale-95 cursor-pointer">
          👑 Promote to Admin
        </button>
      </form>

      <!-- Active Users & Admins Summary List -->
      <div class="pt-2 border-t border-slate-800/80">
        <span class="text-[10px] font-bold uppercase text-slate-400 tracking-wider block mb-2">Registered Accounts Role Overview</span>
        <div class="space-y-1.5 max-h-36 overflow-y-auto pr-1 text-xs">
          <% if (typeof userAccounts !== 'undefined' && userAccounts) { %>
            <% userAccounts.forEach(u => { %>
              <div class="flex items-center justify-between bg-slate-950/80 p-2 rounded-lg border border-slate-800">
                <div class="truncate mr-2">
                  <span class="font-bold text-slate-200 block text-[11px] truncate"><%= u.name %></span>
                  <span class="text-[10px] text-slate-400 block truncate"><%= u.email %></span>
                </div>
                <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase <%= u.role === 'admin' ? 'bg-purple-950 text-purple-300 border border-purple-500/40' : 'bg-slate-900 text-slate-400 border border-slate-800' %>">
                  <%= u.role || 'attendee' %>
                </span>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>

    <!-- 2. Export Event Registrations to CSV / Google Sheet -->
    <div class="glass-panel p-6 rounded-3xl border border-emerald-500/30 space-y-4 shadow-xl lg:col-span-2">
      <div class="flex items-center justify-between border-b border-slate-800 pb-3">
        <div>
          <h2 class="text-base font-black text-white flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            <span>One-Click Export to CSV / Google Sheet</span>
          </h2>
          <p class="text-xs text-slate-400 mt-1">
            Download instant event attendee lists in CSV format for drag & drop import into Google Sheets.
          </p>
        </div>

        <a href="/admin/events/ALL/export-csv" class="bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-400 hover:to-teal-500 text-slate-950 font-black text-xs px-3.5 py-2 rounded-xl transition-all shadow-md active:scale-95 inline-flex items-center gap-1.5">
          <span>📥 Export ALL Data (CSV)</span>
        </a>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left text-xs text-slate-300">
          <thead class="bg-slate-950/90 text-[10px] text-slate-400 uppercase font-mono">
            <tr>
              <th class="p-2.5">Event Title</th>
              <th class="p-2.5">Data Sub-Collection / Tab</th>
              <th class="p-2.5">Registrations</th>
              <th class="p-2.5 text-right">One-Click Export</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/80">
            <% events.forEach(evt => { %>
              <tr class="hover:bg-slate-900/60">
                <td class="p-2.5 font-bold text-white">
                  <%= evt.titleEn %>
                  <div class="text-[10px] text-slate-400 font-normal"><%= evt.date %> | <%= evt.category %></div>
                </td>
                <td class="p-2.5 font-mono text-[11px] text-cyan-300">
                  <span class="bg-slate-950 px-2 py-0.5 rounded border border-slate-800"><%= evt.sheetTabName %></span>
                </td>
                <td class="p-2.5 font-semibold text-slate-300">
                  <%= evt.currentRegistrations %> / <%= evt.capacity %>
                </td>
                <td class="p-2.5 text-right">
                  <a href="/admin/events/<%= evt.id %>/export-csv" class="bg-slate-950 hover:bg-slate-900 text-emerald-400 hover:text-emerald-300 font-bold text-[11px] px-3 py-1.5 rounded-lg border border-slate-800 hover:border-emerald-500/50 inline-flex items-center gap-1 transition-all">
                    <span>📊 Export CSV</span>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- 3. Post New Event Form (Dynamic Data Architecture) -->
  <div class="glass-panel p-6 rounded-3xl border border-cyan-500/30 space-y-6 shadow-2xl">
    <div class="border-b border-slate-800/80 pb-4">
      <h2 class="text-lg font-black text-white flex items-center gap-2">
        <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span>Create New Event & Initialize Data Storage</span>
      </h2>
      <p class="text-xs text-slate-400 mt-0.5">
        Posting an event creates a dedicated Firestore collection map & Google Sheet tab (e.g. <code>event_registrations_evt-[id]</code>) ensuring event records remain clean and unmixed.
      </p>
    </div>

    <form action="/admin/create-event" method="POST" class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1">
            Event Title (English) *
          </label>
          <input type="text" name="titleEn" required placeholder="e.g. National Youth Leadership Summit 2026"
                 class="w-full bg-slate-950 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1">
            Event Title (Bangla)
          </label>
          <input type="text" name="titleBn" placeholder="e.g. জাতীয় যুব নেতৃত্ব সম্মেলন ২০২৬"
                 class="w-full bg-slate-950 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1">
            Category
          </label>
          <select name="category" class="w-full bg-slate-950 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all">
            <option value="Summit">Summit</option>
            <option value="Workshop">Workshop</option>
            <option value="Hackathon">Hackathon</option>
            <option value="Leadership">Leadership</option>
            <option value="Community">Community</option>
            <option value="Civic Action">Civic Action</option>
          </select>
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1">
            Event Date *
          </label>
          <input type="text" name="date" required placeholder="e.g. Nov 15, 2026"
                 class="w-full bg-slate-950 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1">
            Event Time
          </label>
          <input type="text" name="time" placeholder="e.g. 10:00 AM - 05:00 PM"
                 class="w-full bg-slate-950 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1">
            Location (English) *
          </label>
          <input type="text" name="locationEn" required placeholder="e.g. KIB Auditorium, Farmgate, Dhaka"
                 class="w-full bg-slate-950 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1">
            Capacity (Max Attendees)
          </label>
          <input type="number" name="capacity" value="200"
                 class="w-full bg-slate-950 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1">
            Ticket Price (BDT) - Set 0 for Free
          </label>
          <input type="number" name="price" value="0" placeholder="0 for Free, or e.g. 500"
                 class="w-full bg-slate-950 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1">
            Organizer Name
          </label>
          <input type="text" name="organizer" placeholder="Survivor's Path Youth Council"
                 class="w-full bg-slate-950 border border-slate-700 focus:border-cyan-400 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none transition-all" />
        </div>
      </div>

      <div>
        <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1">
          Description (English)
        </label>
        <textarea name="descriptionEn" rows="2" placeholder="Brief event objective and agenda..."
                  class="w-full bg-slate-950 border border-slate-700 focus:border-cyan-400 rounded-xl p-3 text-xs text-white focus:outline-none transition-all"></textarea>
      </div>

      <div class="flex justify-end pt-2">
        <button type="submit" class="bg-gradient-to-r from-cyan-400 via-sky-500 to-blue-600 hover:from-cyan-300 hover:to-blue-500 text-slate-950 font-black text-xs px-6 py-3 rounded-xl transition-all shadow-lg shadow-cyan-500/20 active:scale-95 cursor-pointer">
          🚀 Publish Event & Create Data Collection
        </button>
      </div>
    </form>
  </div>
  <div class="glass-panel p-6 rounded-3xl border border-cyan-500/30 space-y-6 shadow-2xl">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-800/80 pb-4">
      <div>
        <h2 class="text-lg font-black text-white flex items-center gap-2">
          <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          <span>Registrations & Approval Queue</span>
        </h2>
        <p class="text-xs text-slate-400 mt-0.5">
          Review payment Transaction IDs for paid events. Click "Approve & Issue Ticket" to update status in Google Sheets and unlock tickets.
        </p>
      </div>

      <div class="flex items-center gap-2 text-xs">
        <span class="px-3 py-1 rounded-lg bg-amber-950 text-amber-300 border border-amber-500/40 font-bold">
          <%= allRegistrations.filter(r => r.status === 'Pending').length %> Pending Approval
        </span>
        <span class="px-3 py-1 rounded-lg bg-emerald-950 text-emerald-300 border border-emerald-500/40 font-bold">
          <%= allRegistrations.filter(r => r.status === 'Confirmed' || r.status === 'Registered').length %> Confirmed
        </span>
      </div>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
      <table class="w-full text-left text-xs text-slate-300">
        <thead class="bg-slate-950/90 text-[10px] text-slate-400 uppercase font-mono tracking-wider">
          <tr>
            <th class="p-3">Ticket ID</th>
            <th class="p-3">Attendee Name</th>
            <th class="p-3">Event</th>
            <th class="p-3">Payment Info</th>
            <th class="p-3">Transaction ID</th>
            <th class="p-3">Status</th>
            <th class="p-3 text-right">Action / Ticket</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/80">
          <% if (allRegistrations.length === 0) { %>
            <tr>
              <td colspan="7" class="p-6 text-center text-slate-500 italic">No registrations recorded yet.</td>
            </tr>
          <% } else { %>
            <% allRegistrations.forEach(reg => { %>
              <tr class="hover:bg-slate-900/60 transition-all">
                <td class="p-3 font-mono font-bold text-amber-400"><%= reg.id %></td>
                <td class="p-3 font-semibold text-white">
                  <div><%= reg.fullName %></div>
                  <div class="text-[10px] text-slate-400 font-normal"><%= reg.email %> | <%= reg.phone %></div>
                </td>
                <td class="p-3 font-medium text-slate-200">
                  <%= reg.eventTitle %>
                </td>
                <td class="p-3">
                  <% if (reg.isPaidEvent) { %>
                    <span class="px-2 py-0.5 rounded text-[10px] font-black bg-cyan-950 text-cyan-300 border border-cyan-500/30">
                      PAID (৳<%= reg.paymentAmount %>)
                    </span>
                  <% } else { %>
                    <span class="px-2 py-0.5 rounded text-[10px] font-black bg-emerald-950 text-emerald-300 border border-emerald-500/30">
                      FREE
                    </span>
                  <% } %>
                </td>
                <td class="p-3 font-mono text-cyan-200">
                  <% if (reg.transactionId) { %>
                    <div class="bg-slate-950 px-2 py-1 rounded border border-slate-800 inline-block font-bold">
                      <%= reg.transactionId %> (<%= reg.paymentMethod || 'bKash' %>)
                    </div>
                  <% } else { %>
                    <span class="text-slate-500 text-[10px]">N/A (Free Event)</span>
                  <% } %>
                </td>
                <td class="p-3">
                  <% if (reg.status === 'Pending') { %>
                    <span class="px-2.5 py-1 rounded-lg text-[10px] font-black bg-amber-950/90 text-amber-300 border border-amber-500/50 flex items-center gap-1.5 w-fit">
                      <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
                      <span>Pending Approval</span>
                    </span>
                  <% } else if (reg.status === 'Confirmed' || reg.status === 'Registered') { %>
                    <span class="px-2.5 py-1 rounded-lg text-[10px] font-black bg-emerald-950/90 text-emerald-300 border border-emerald-500/50 flex items-center gap-1.5 w-fit">
                      <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
                      <span>Confirmed</span>
                    </span>
                  <% } else { %>
                    <span class="px-2.5 py-1 rounded-lg text-[10px] font-black bg-rose-950/90 text-rose-300 border border-rose-500/50 flex items-center gap-1.5 w-fit">
                      <span>Waitlist</span>
                    </span>
                  <% } %>
                </td>
                <td class="p-3 text-right">
                  <% if (reg.status === 'Pending') { %>
                    <form action="/admin/registrations/<%= reg.id %>/approve" method="POST" class="inline-block">
                      <button type="submit" 
                              class="bg-gradient-to-r from-emerald-400 to-teal-500 hover:from-emerald-300 hover:to-teal-400 text-slate-950 font-black text-[11px] px-3.5 py-2 rounded-xl transition-all shadow-md active:scale-95 cursor-pointer">
                        ✓ Approve & Issue Ticket
                      </button>
                    </form>
                  <% } else { %>
                    <a href="/tickets/<%= reg.id %>" 
                       target="_blank"
                       class="text-[11px] font-bold text-cyan-400 hover:text-cyan-300 bg-slate-950 px-3 py-1.5 rounded-xl border border-slate-800 hover:border-cyan-500/50 inline-block transition-all">
                      View Ticket ↗
                    </a>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Bulk Email Broadcast System -->
  <div class="glass-panel p-6 rounded-3xl border border-indigo-500/30 space-y-6 shadow-2xl">
    <div class="border-b border-slate-800/80 pb-4">
      <h2 class="text-lg font-black text-white flex items-center gap-2">
        <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        <span>Bulk Email System (Nodemailer & PDF Attachment Engine)</span>
      </h2>
      <p class="text-xs text-slate-400 mt-0.5">
        Send personalized emails with individual PDF Ticket Passes attached to all <strong>"Confirmed"</strong> attendees for a selected event.
      </p>
    </div>

    <form action="/admin/send-bulk-email" method="POST" class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            Target Event Audience
          </label>
          <select name="eventId" required class="w-full bg-slate-950 border border-slate-700 focus:border-indigo-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none transition-all">
            <option value="ALL">All Confirmed Attendees Across All Events</option>
            <% events.forEach(evt => { %>
              <option value="<%= evt.id %>"><%= evt.titleEn %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5">
            Email Subject Line
          </label>
          <input type="text" name="subject" required 
                 value="Survivor's Path - Your Official Ticket Pass & Event Details"
                 class="w-full bg-slate-950 border border-slate-700 focus:border-indigo-400 rounded-xl px-4 py-3 text-sm text-white focus:outline-none transition-all" />
        </div>
      </div>

      <div>
        <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider mb-1.5 flex items-center justify-between">
          <span>Custom Instructions / Announcement Message</span>
          <span class="text-[10px] text-indigo-400 font-mono">Dynamic Tags: {NAME}, {EVENT}, {TICKET_ID}, {DATE}</span>
        </label>
        <textarea name="customInstructions" rows="4" required
                  class="w-full bg-slate-950 border border-slate-700 focus:border-indigo-400 rounded-xl p-4 text-xs font-sans text-slate-200 focus:outline-none transition-all leading-relaxed"
        >Dear {NAME},

We are thrilled to confirm your registration for {EVENT}. 

Your official ticket pass ID is {TICKET_ID}. Please review the venue guidelines and find your personalized PDF Gate Pass attached to this email.

If you have any questions, reply to this email or reach out to our team at support@survivorspath.org.

Warm regards,
Survivor's Path Executive Team</textarea>
      </div>

      <div class="flex items-center justify-between pt-2">
        <div class="text-[11px] text-slate-400 flex items-center gap-1.5">
          <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path></svg>
          <span>Each email automatically attaches the attendee's personal <strong>PDF Ticket Pass</strong>.</span>
        </div>

        <button type="submit" 
                class="bg-gradient-to-r from-indigo-500 via-sky-500 to-cyan-500 hover:from-indigo-400 hover:to-cyan-400 text-slate-950 font-black text-xs px-6 py-3.5 rounded-xl transition-all shadow-lg shadow-indigo-500/20 active:scale-95 cursor-pointer">
          ✉ Send All Confirmed Emails
        </button>
      </div>
    </form>
  </div>

  <!-- Google Sheets Integration & Configuration Panel -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <div class="glass-panel p-6 rounded-2xl border border-slate-800 space-y-4 lg:col-span-1">
      <h3 class="text-sm font-bold text-white uppercase tracking-wider text-cyan-400">
        Service Account Setup
      </h3>

      <div class="space-y-3 text-xs text-slate-300">
        <div>
          <span class="text-[10px] text-slate-500 uppercase font-bold block">Spreadsheet ID</span>
          <code class="bg-slate-950 px-2 py-1 rounded text-cyan-300 text-[11px] block mt-0.5 truncate">
            <%= config.spreadsheetId || 'Not set (using local mock store)' %>
          </code>
        </div>

        <div>
          <span class="text-[10px] text-slate-500 uppercase font-bold block">Service Account Email</span>
          <code class="bg-slate-950 px-2 py-1 rounded text-cyan-300 text-[11px] block mt-0.5 truncate">
            <%= config.clientEmail || 'Not set (using local mock store)' %>
          </code>
        </div>

        <div>
          <span class="text-[10px] text-slate-500 uppercase font-bold block">Private Key Status</span>
          <span class="font-bold <%= config.hasPrivateKey ? 'text-emerald-400' : 'text-amber-400' %>">
            <%= config.hasPrivateKey ? '✓ Configured' : '⚠ Missing (Set GOOGLE_PRIVATE_KEY in .env)' %>
          </span>
        </div>
      </div>

      <!-- Test Append Form -->
      <form action="/admin/sheets/test-append" method="POST" class="pt-2">
        <label class="block text-[10px] text-slate-400 uppercase font-bold mb-1">Target Event Tab</label>
        <select name="eventId" class="w-full bg-slate-950 border border-slate-700 text-xs text-white p-2 rounded-lg mb-3">
          <% events.forEach(evt => { %>
            <option value="<%= evt.id %>"><%= evt.sheetTabName %></option>
          <% }) %>
        </select>

        <button type="submit" class="w-full bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-400 hover:to-teal-500 text-slate-950 font-extrabold text-xs py-2.5 rounded-xl transition-all shadow cursor-pointer">
          <%= i18n.sheets.appendTest %>
        </button>
      </form>
    </div>

    <!-- Synced Tabs Data Viewer -->
    <div class="glass-panel p-6 rounded-2xl border border-slate-800 space-y-6 lg:col-span-2">
      
      <div class="flex items-center justify-between">
        <h3 class="text-sm font-bold text-white uppercase tracking-wider text-cyan-400">
          Live Synced Rows by Google Sheet Tab
        </h3>
        <span class="text-xs text-slate-400">Mode: <strong><%= config.mode === 'live' ? 'Live API' : 'Persisted Local Store' %></strong></span>
      </div>

      <% const tabNames = Object.keys(localData); %>
      <% if (tabNames.length === 0) { %>
        <div class="p-8 text-center text-xs text-slate-400 border border-dashed border-slate-800 rounded-xl">
          No records submitted yet. Register for an event or click "Test Append" to see live row appending in action!
        </div>
      <% } else { %>

        <% tabNames.forEach(tab => { %>
          <div class="space-y-2">
            <div class="flex items-center justify-between text-xs font-bold text-emerald-300 bg-emerald-950/40 px-3 py-1.5 rounded-lg border border-emerald-500/20">
              <span>Sheet Tab: '<%= tab %>'</span>
              <span><%= localData[tab].length %> rows</span>
            </div>

            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs text-slate-300">
                <thead class="bg-slate-950/80 text-[10px] text-slate-400 uppercase font-mono">
                  <tr>
                    <th class="p-2">ID</th>
                    <th class="p-2">Full Name</th>
                    <th class="p-2">Email</th>
                    <th class="p-2">Status</th>
                    <th class="p-2">Timestamp</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/60">
                  <% localData[tab].forEach(row => { %>
                    <tr class="hover:bg-slate-900/60">
                      <td class="p-2 font-mono text-amber-400"><%= row.id %></td>
                      <td class="p-2 font-semibold text-white"><%= row.fullName %></td>
                      <td class="p-2"><%= row.email %></td>
                      <td class="p-2">
                        <span class="px-2 py-0.5 rounded text-[10px] font-bold <%= row.status === 'Waitlist' ? 'bg-rose-950 text-rose-300 border border-rose-500/30' : (row.status === 'Pending' ? 'bg-amber-950 text-amber-300 border border-amber-500/30' : 'bg-emerald-950 text-emerald-300 border border-emerald-500/30') %>">
                          <%= row.status %>
                        </span>
                      </td>
                      <td class="p-2 text-[10px] text-slate-400"><%= new Date(row.registeredAt).toLocaleTimeString() %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        <% }) %>

      <% } %>

    </div>

  </div>

</div>

<%- include('partials/footer') %>

